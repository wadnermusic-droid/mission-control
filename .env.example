# ============================================================
# MISSION CONTROL — Environment Variables
# ============================================================
#
# Copy this file to .env.local and fill in the values:
# cp .env.example .env.local
#
# NEVER commit .env.local — it is listed in .gitignore.
#
# ============================================================
# Runtime
# ============================================================
NODE_ENV=development

# ============================================================
# Database
# ============================================================
# SQLite (local development):
DATABASE_URL="file:./dev.db"

# ============================================================
# Authentication
# ============================================================
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE-ME-generate-a-real-secret-with-openssl-rand-base64-32"
JWT_ACCESS_TOKEN_EXPIRY="30m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# ============================================================
# CORS
# ============================================================
# Leave empty in development (localhost is auto-allowed)
ALLOWED_ORIGINS=""

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_TASKS_MAX=50
RATE_LIMIT_TASKS_WINDOW_SECONDS=60
RATE_LIMIT_TOOLS_MAX=30
RATE_LIMIT_TOOLS_WINDOW_SECONDS=60

# ============================================================
# Security
# ============================================================
ENABLE_RATE_LIMITING=true
ENABLE_CSRF_PROTECTION=true
ENABLE_REQUEST_LOGGING=true
MAX_BODY_SIZE=1048576

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ============================================================
# Public (Client-Side)
# ============================================================
NEXT_PUBLIC_APP_NAME="Mission Control"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
